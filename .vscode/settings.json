    "editor.tokenColorCustomizations": {
        "comments": "#4a5a6a",
        "strings": "#28c880",
        "keywords": "#e84040",
        "numbers": "#e8a020",
        "types": "#3090e8",
        "functions": "#20d0e8",
        "variables": "#e8ecf0",
        "textMateRules": [
            {
                "scope": [
                    "markup.heading",
                    "entity.name.section.markdown"
                ],
                "settings": {
                    "foreground": "#e8ecf0",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": [
                    "markup.bold.markdown"
                ],
                "settings": {
                    "foreground": "#e8ecf0",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": [
                    "markup.italic.markdown"
                ],
                "settings": {
                    "foreground": "#8a9ab0",
                    "fontStyle": "italic"
                }
            },
            {
                "scope": [
                    "markup.inline.raw",
                    "markup.fenced_code.block.markdown"
                ],
                "settings": {
                    "foreground": "#20d0e8"
                }
            },
            {
                "scope": [
                    "markup.underline.link.markdown",
                    "string.other.link.title.markdown"
                ],
                "settings": {
                    "foreground": "#3090e8"
                }
            },
            {
                "scope": [
                    "punctuation.definition.tag",
                    "entity.name.tag"
                ],
                "settings": {
                    "foreground": "#a060e8"
                }
            },
            {
                "scope": [
                    "constant.language.json",
                    "support.type.property-name.json"
                ],
                "settings": {
                    "foreground": "#3090e8"
                }
            }
        ]
    },
    "markdown.preview.fontFamily": "'IBM Plex Mono', monospace",
    "markdown.preview.fontSize": 14,
    "markdown.preview.lineHeight": 1.7
}
