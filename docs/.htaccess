# Página 404 customizada
ErrorDocument 404 /404.html

# Esconder extensão .html nas URLs
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirecionar .html → sem extensão (301 permanente)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # Servir .html quando URL sem extensão for solicitada
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]

  # --- ALIASES & SHORT LINKS ---
  RewriteRule ^rede$ /rede-recorrente-1999-2026 [L,R=301]
  RewriteRule ^lava-jato$ /operacao_lava_jato [L,R=301]
  RewriteRule ^master$ /banco-master-compliance-zero [L,R=301]
  RewriteRule ^pcc$ /pcc-cv-intel-dashboard-2026 [L,R=301]
</IfModule>

# --- RELATIONSHIP MAPPING (HTTP Link Headers) ---
<IfModule mod_headers.c>
  # Vínculos para: Rede Recorrente
  <Files "rede-recorrente-1999-2026.html">
    Header add Link "</operacao_lava_jato>; rel=\"related\"; title=\"Lava Jato\""
    Header add Link "</banco-master-compliance-zero>; rel=\"related\"; title=\"Banco Master\""
    Header add Link "</satiagraha>; rel=\"related\"; title=\"Satiagraha\""
    Header add Link "</operacao_castelo_de_areia>; rel=\"related\"; title=\"Castelo de Areia\""
    Header add Link "</republica-capturada>; rel=\"related\"; title=\"República Capturada\""
    Header add Link "</thread-operacoes-brasil>; rel=\"related\"; title=\"Thread Integrado\""
  </Files>

  # Vínculos para: Banco Master
  <Files "banco-master-compliance-zero.html">
    Header add Link "</rede-recorrente-1999-2026>; rel=\"related\"; title=\"Rede Recorrente\""
    Header add Link "</carbono_oculto>; rel=\"related\"; title=\"Carbono Oculto (REAG)\""
    Header add Link "</thread-operacoes-brasil>; rel=\"related\"; title=\"Thread Integrado\""
  </Files>

  # Vínculos para: Lava Jato
  <Files "operacao_lava_jato.html">
    Header add Link "</rede-recorrente-1999-2026>; rel=\"related\"; title=\"Rede Recorrente\""
    Header add Link "</banco-master-compliance-zero>; rel=\"related\"; title=\"Banco Master\""
    Header add Link "</pcc-cv-intel-dashboard-2026>; rel=\"related\"; title=\"PCC Intelligence\""
  </Files>

  # Vínculos para: PCC & CV Intel
  <Files "pcc-cv-intel-dashboard-2026.html">
    Header add Link "</rede-recorrente-1999-2026>; rel=\"related\"; title=\"Rede Recorrente\""
    Header add Link "</operacao_lava_jato>; rel=\"related\"; title=\"Lava Jato\""
    Header add Link "</carbono_oculto>; rel=\"related\"; title=\"Carbono Oculto\""
  </Files>
</IfModule>
